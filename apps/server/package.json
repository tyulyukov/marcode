    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@marcode/contracts": "workspace:*",
    "@marcode/shared": "workspace:*",
    "@marcode/web": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
