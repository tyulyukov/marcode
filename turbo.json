{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "MARCODE_LOG_WS_EVENTS",
    "MARCODE_MODE",
    "MARCODE_PORT",
    "MARCODE_NO_BROWSER",
    "MARCODE_HOME",
    "MARCODE_AUTH_TOKEN",
    "MARCODE_DESKTOP_WS_URL",
    "MARCODE_JIRA_CLIENT_ID",
    "MARCODE_JIRA_CLIENT_SECRET",
    "MARCODE_JIRA_REDIRECT_URI"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@marcode/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
